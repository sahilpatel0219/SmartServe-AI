# ── Django Core ────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Relational Database (SQLite in dev, Postgres in prod) ──────────────────────
# Leave blank to use SQLite (default for dev)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# For Postgres, uncomment and fill:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=smartserve_db
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Local dev: mongodb://localhost:27017
# Atlas:     mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=smartserve_db

# ── Email / SMTP ───────────────────────────────────────────────────────────────
# Use 'console' in dev (prints to terminal). Change to 'smtp' for prod.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ── AI / LLM Assistant ─────────────────────────────────────────────────────────
# Set to 'openai', 'anthropic', or leave blank to use stats-based fallback
LLM_PROVIDER=
LLM_API_KEY=

# ── File Storage (local dev; switch to S3 for prod) ───────────────────────────
MEDIA_ROOT=media
MEDIA_URL=/media/

# ── Security (production) ──────────────────────────────────────────────────────
# CSRF_COOKIE_SECURE=True
# SESSION_COOKIE_SECURE=True
